---
interface Props {
  id?: string;
  as?: "button" | "a";
  variant?: "primary" | "secondary" | "destructive" | "outline" | "ghost" | "link";
  size?: "default" | "sm" | "md" | "lg" | "icon" | "icon-sm" | "none";
  href?: string;
  target?: string;
  rel?: string;
  "aria-label"?: string;
}

const {
  id,
  as = "button",
  variant = "primary",
  size = "default",
  href,
  target,
  rel,
  "aria-label": ariaLabel,
} = Astro.props as Props;
if (as === "a" && !href) {
  throw new Error("Button: `href` is required when `as` is set to `a`.");
}
const resolvedRel = rel ?? (target === "_blank" ? "noopener noreferrer" : undefined);
---

{
  as === "a" ? (
    <a
      id={id}
      href={href}
      target={target}
      rel={resolvedRel}
      aria-label={ariaLabel}
      data-slot="button"
      data-variant={variant}
      data-size={size}
    >
      <slot />
    </a>
  ) : (
    <button id={id} data-slot="button" data-variant={variant} data-size={size}>
      <slot />
    </button>
  )
}
